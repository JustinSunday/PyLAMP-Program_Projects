#!/usr/bin/env python3
import os
import shutil

# Source and destination directories
downloads_dir = "/home/justinsunday/Downloads"
dest_dir = "files"

# Create destination subfolders
categories = {
    "images": ('.jpg', '.jpeg', '.png', '.gif', '.bmp'),
    "videos": ('.mp4', '.mkv', '.mov', '.avi', '.flv'),
    "music":  ('.mp3', '.wav', '.flac', '.aac'),
    "documents": ('.pdf', '.doc', '.docx', '.txt', '.ppt', '.pptx', '.xls', '.xlsx'),
    "links": ('.url', '.webloc', '.desktop')
}

# Create main folder
os.makedirs(dest_dir, exist_ok=True)
for cat in categories:
    os.makedirs(os.path.join(dest_dir, cat), exist_ok=True)
os.makedirs(os.path.join(dest_dir, 'others'), exist_ok=True)

# Process files
for file in os.listdir(downloads_dir):
    src_file = os.path.join(downloads_dir, file)
    if os.path.isfile(src_file):
        moved = False
        for cat, exts in categories.items():
            if file.lower().endswith(exts):
                shutil.copy(src_file, os.path.join(dest_dir, cat, file))
                moved = True
                break
        if not moved:
            shutil.copy(src_file, os.path.join(dest_dir, 'others', file))

print("Files copied and organized successfully!")
